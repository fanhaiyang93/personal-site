---
import { skillGroups } from '../data/skills';
---
<section id="skills" class="py-20 px-6 border-t border-zinc-800">
  <div class="mx-auto max-w-5xl">
    <div class="font-mono text-accent text-sm tracking-widest mb-2">// 技能</div>
    <h2 class="text-2xl font-bold text-white mb-10">技术能力</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {skillGroups.map((group) => (
        <div>
          <h3 class="text-zinc-400 text-sm font-semibold mb-3 uppercase tracking-wider">
            {group.category}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class="px-3 py-1 bg-zinc-900 border border-zinc-700 text-zinc-300 text-xs rounded-full hover:border-accent hover:text-accent transition-colors">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
