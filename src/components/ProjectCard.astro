---
interface Props {
  title: string;
  id: string;
  date: string;
  company: string;
  tags: string[];
  summary: string;
  featured?: boolean;
}
const { title, id, date, company, tags, summary, featured = false } = Astro.props;
---
<a
  href={`/projects/${id}`}
  class:list={[
    'block p-6 rounded-lg border transition-all duration-200 group',
    'hover:border-accent hover:-translate-y-0.5',
    featured ? 'border-zinc-600 bg-zinc-900/50' : 'border-zinc-800 bg-zinc-900/20',
  ]}
>
  <div class="flex items-start justify-between mb-3">
    <div>
      <h3 class="text-white font-semibold text-base group-hover:text-accent transition-colors leading-tight mb-1">
        {title}
      </h3>
      <div class="text-zinc-500 text-xs font-mono">
        {company} · {date}
      </div>
    </div>
    {featured && (
      <span class="text-xs border border-accent text-accent px-2 py-0.5 rounded font-mono ml-3 shrink-0">
        精选
      </span>
    )}
  </div>
  <p class="text-zinc-400 text-sm leading-relaxed mb-4">{summary}</p>
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="text-xs bg-zinc-800 text-zinc-400 px-2 py-0.5 rounded font-mono">
        {tag}
      </span>
    ))}
  </div>
</a>
